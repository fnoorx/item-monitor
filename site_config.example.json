{
  "login_link_xpath": "//a[contains(@href, 'login') or contains(normalize-space(.), 'Log in')]",
  "username_locators": [
    { "by": "css_selector", "value": "input[type='email']" },
    { "by": "css_selector", "value": "input[name*='user']" }
  ],
  "password_locators": [
    { "by": "css_selector", "value": "input[type='password']" }
  ],
  "secondary_auth_button_css": "button[type='submit']",
  "account_menu_css": "button[aria-haspopup='menu'], [role='button'][aria-haspopup='menu']",
  "item_selector": "a[href]",
  "next_button_selector": "button[aria-label*='next'], a[rel='next']",
  "overlay_selector": "[role='dialog'], [class*='overlay']",
  "card_ancestor_xpaths": [
    "./ancestor::article[1]",
    "./ancestor::li[1]",
    "./ancestor::div[.//a][1]"
  ]
}
